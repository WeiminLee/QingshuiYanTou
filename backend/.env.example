# LLM
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://mimimax.cn/v1
LLM_MODEL=MiniMax-M2.7-highspeed

LLM_FALLBACK_BASE_URL=http://localhost:4000/v1
LLM_FALLBACK_API_KEY=your_fallback_api_key_here
LLM_FALLBACK_MODEL=minmax2.5


# Tencent Cloud Hunyuan Embedding API（Phase 06 - 替代本地服务）
HUNYUAN_API_KEY=your_hunyuan_api_key_here
HUNYUAN_MODEL=hunyuan-embedding
HUNYUAN_EMBEDDING_URL=https://api.hunyuan.cloud.tencent.com/v1/embeddings

# 本地 Embedding 服务（已弃用，请使用上方 Hunyuan）
EMBEDDING_API_URL=http://localhost:8000
EMBEDDING_API_KEY=

# 数据库
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
MONGODB_URL=mongodb://user:password@localhost:27017/dbname
REDIS_URL=redis://localhost:6379/0


# Neo4j（图数据库）
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# 向量数据库（Qdrant）
VECTOR_DB_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=qingshui
PRE_SEARCH_TOP_K=5


# API 访问密钥
API_KEY=your_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# LangChain 在线追踪（禁用）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# TuShare（数据源）
TUSHARE_TOKEN=your_tushare_token_here

# minishare（备选数据源，授权码从 minidoc.pages.dev 获取）
# 研报授权码
MINISHARE_RESEARCH_TOKEN=
# 互动易（董秘问答）授权码
MINISHARE_IRM_TOKEN=
